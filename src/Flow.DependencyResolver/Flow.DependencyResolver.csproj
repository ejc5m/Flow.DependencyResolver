<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup Label="Code">
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<PropertyGroup Label="Package">
		<PackageId>Flow.DependencyResolver</PackageId>
		<Version>1.0.0-beta.2</Version>
		<Authors>ejc5million</Authors>
		<Description>A simple dependency resolver for dotnet</Description>
		<Copyright>© 2026 ejc5million</Copyright>
		
		<PackageLicenseFile>LICENSE.md</PackageLicenseFile>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
		
		<RepositoryUrl>https://github.com/ejc5m/Flow.DependencyResolver</RepositoryUrl>
		<PackageProjectUrl>https://github.com/ejc5m/Flow.DependencyResolver</PackageProjectUrl>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>

		<IncludeSymbols>true</IncludeSymbols>
		<SymbolPackageFormat>snupkg</SymbolPackageFormat>
	</PropertyGroup>

	<ItemGroup Label="Package">
		<None Include="..\..\README.md" Pack="true" PackagePath="\" />
		<None Include="..\..\LICENSE.md" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>
